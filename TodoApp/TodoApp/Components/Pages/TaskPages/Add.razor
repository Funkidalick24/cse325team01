@page "/tasks/add"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using TodoApp.Models
@using TodoApp.Models.Enums
@using TodoApp.Services
@attribute [Authorize]
@inject ITaskService TaskService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager
@inject ILogger<Add> Logger

<PageTitle>Add New Task</PageTitle>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0 icon-text"><span class="ui-icon" aria-hidden="true">add_task</span><span>Add New Task</span></h5>
        </div>
        <div class="card-body">
            @if (!string.IsNullOrWhiteSpace(FormError))
            {
                <div class="alert alert-danger" role="alert" aria-live="polite">
                    @FormError
                </div>
            }

            @if (CurrentTask != null)
            {
                <EditForm Model="CurrentTask" OnValidSubmit="HandleValidSubmit" OnInvalidSubmit="InvalidSubmit" FormName="Add">
                    <AntiforgeryToken />
                    <DataAnnotationsValidator />
                    <ValidationSummary />

                    <div class="form-group mb-3">
                        <label for="title" class="form-label icon-text"><span class="ui-icon" aria-hidden="true">title</span><span>Title</span></label>
                        <InputText id="title" class="form-control" @bind-Value="CurrentTask.Title" placeholder="Task title" />
                        <ValidationMessage For="() => CurrentTask.Title" class="text-danger" />
                    </div>

                    <div class="form-group mb-3">
                        <label for="description" class="form-label icon-text"><span class="ui-icon" aria-hidden="true">notes</span><span>Description (Optional)</span></label>
                        <InputTextArea id="description" class="form-control" @bind-Value="CurrentTask.Description" rows="3" placeholder="Task description" />
                        <ValidationMessage For="() => CurrentTask.Description" class="text-danger" />
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6 form-group">
                            <label for="dueDate" class="form-label icon-text"><span class="ui-icon" aria-hidden="true">event</span><span>Due Date</span></label>
                            <InputDate id="dueDate" class="form-control" @bind-Value="CurrentTask.DueDate" />
                        </div>
                        <div class="col-md-6 form-group">
                            <label for="priority" class="form-label icon-text"><span class="ui-icon" aria-hidden="true">flag</span><span>Priority</span></label>
                            <InputSelect id="priority" class="form-select" @bind-Value="CurrentTask.Priority">
                                @foreach (var priority in Enum.GetValues<Priority>())
                                {
                                    <option value="@priority">@priority.ToString()</option>
                                }
                            </InputSelect>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label icon-text"><span class="ui-icon" aria-hidden="true">category</span><span>Category</span></label>
                        <div class="category-radio-group">
                            <InputRadioGroup @bind-Value="CurrentTask.Category">
                                @foreach (var category in Enum.GetValues<TaskCategory>())
                                {
                                    <label class="category-radio category-@category.ToString().ToLowerInvariant()">
                                        <InputRadio Value="@category" />
                                        <span>@category.GetDisplayLabel()</span>
                                    </label>
                                }
                            </InputRadioGroup>
                        </div>
                    </div>

                    <div class="mt-4">
                        <a href="/tasks" class="btn btn-secondary me-2 icon-text"><span class="ui-icon" aria-hidden="true">close</span><span>Cancel</span></a>
                        <button type="submit" class="btn btn-primary icon-text" disabled="@IsSubmitting" aria-busy="@IsSubmitting">
                            <span class="ui-icon" aria-hidden="true">save</span>
                            <span>@(IsSubmitting ? "Saving..." : "Save")</span>
                        </button>
                    </div>
                </EditForm>
            }
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromForm(FormName = "Add")]
    public TaskItem? CurrentTask { get; set; }

    private string UserId { get; set; } = string.Empty;
    private string? FormError { get; set; }
    private bool IsSubmitting { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        UserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
        CurrentTask ??= new TaskItem { UserId = UserId };
    }

    public async Task HandleValidSubmit()
    {
        FormError = null;
        IsSubmitting = true;
        try
        {
            if (CurrentTask != null)
            {
                CurrentTask.UserId = UserId;
                await TaskService.CreateTaskAsync(CurrentTask, UserId);
            }

            NavigationManager.NavigateTo("/tasks");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to create task for user {UserId}", UserId);
            FormError = "We couldn't save your task right now. Please try again.";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    protected void InvalidSubmit()
    {
        FormError = "Please fix the highlighted validation issues before saving.";
    }
}
