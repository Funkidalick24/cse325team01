@using TodoApp.Models.Enums

<div class="category-filter">
    <a href="/tasks" class="filter-btn text-decoration-none @(SelectedCategory == null ? "active" : "")">
        All Tasks
    </a>

    @foreach (var category in Enum.GetValues<TaskCategory>())
    {
        <a href="/tasks?category=@category.ToString().ToLowerInvariant()" class="filter-btn text-decoration-none category-@category.ToString().ToLowerInvariant() @(SelectedCategory == category ? "active" : "")">
            <span class="category-dot"></span>
            @category.GetDisplayLabel()
        </a>
    }
</div>

@code {
    [Parameter] public TaskCategory? SelectedCategory { get; set; }
}
