@using TodoApp.Models
@using TodoApp.Models.Enums

@if (Compact)
{
    <article class="task-card task-card-compact @(Task.IsCompleted ? "completed" : "")">
        <div class="task-compact-check">
            <form method="post" action="/api/tasks/toggle/@Task.Id" class="m-0 p-0">
                <AntiforgeryToken />
                <button type="submit" class="btn-icon task-checkbox-btn" aria-label="@(Task.IsCompleted ? "Mark task as not completed" : "Mark task as completed")">
                    @if (Task.IsCompleted)
                    {
                        <span class="task-checkbox-check" aria-hidden="true">✓</span>
                    }
                </button>
            </form>
        </div>

        <div class="task-compact-content">
            <h4 class="task-title mb-0 @(Task.IsCompleted ? "text-strikethrough text-muted" : "")">@Task.Title</h4>
            <div class="task-compact-meta icon-text-tight">
                <span class="ui-icon" aria-hidden="true">task_alt</span>
                <span>Completed @GetCompletedLabel()</span>
            </div>
        </div>

        <a href="/tasks/edit/@Task.Id" class="task-compact-link icon-text-tight" aria-label="Edit task">
            <span class="ui-icon" aria-hidden="true">edit</span>
            <span>Edit</span>
        </a>
    </article>
}
else
{
    <article class="task-card task-card-focus @(GetCardAccentClass()) @(Task.IsCompleted ? "completed" : "")">
        <div class="task-card-header">
            <div class="task-title-group d-flex align-items-start">
                <form method="post" action="/api/tasks/toggle/@Task.Id" class="m-0 p-0 me-2 d-flex align-items-center">
                    <AntiforgeryToken />
                    <button type="submit" class="btn-icon task-checkbox-btn p-0 m-0 d-flex align-items-center" aria-label="@(Task.IsCompleted ? "Mark task as not completed" : "Mark task as completed")">
                        @if (Task.IsCompleted)
                        {
                            <span class="task-checkbox-check" aria-hidden="true">✓</span>
                        }
                    </button>
                </form>
                <div>
                    <div class="task-title-line">
                        <h4 class="task-title mb-0 @(Task.IsCompleted ? "text-strikethrough text-muted" : "")">@Task.Title</h4>
                        @if (IsOverdue)
                        {
                            <span class="task-flag-overdue icon-text-tight">
                                <span class="ui-icon" aria-hidden="true">warning</span>
                                <span>Overdue</span>
                            </span>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(Task.Description))
                    {
                        <p class="task-description text-muted">@Task.Description</p>
                    }
                </div>
            </div>
        </div>

        <div class="task-footer">
            @if (Task.DueDate.HasValue)
            {
                <span class="task-footer-item icon-text @(IsOverdue ? "is-alert" : "")">
                    <span class="ui-icon" aria-hidden="true">schedule</span>
                    <span>@FormatDueDate(Task.DueDate.Value)</span>
                </span>
            }
            <span class="task-footer-item icon-text">
                <span class="ui-icon" aria-hidden="true">category</span>
                <span>@GetCategoryLabel()</span>
            </span>
            <span class="task-footer-item icon-text">
                <span class="ui-icon" aria-hidden="true">@GetPriorityIcon()</span>
                <span>@Task.Priority Priority</span>
            </span>
        </div>
    </article>
}

@code {
    [Parameter] public TaskItem Task { get; set; } = null!;
    [Parameter] public bool Compact { get; set; }

    private bool IsOverdue => !Task.IsCompleted && Task.DueDate.HasValue && Task.DueDate.Value.Date < DateTime.UtcNow.Date;

    private string GetCardAccentClass()
    {
        if (IsOverdue)
        {
            return "task-card-overdue";
        }

        return Task.Priority switch
        {
            Priority.High => "task-card-high",
            Priority.Medium => "task-card-medium",
            _ => "task-card-low"
        };
    }

    private string GetCompletedLabel()
    {
        if (!Task.CompletedAt.HasValue)
        {
            return "recently";
        }

        var elapsed = DateTime.UtcNow - Task.CompletedAt.Value;

        if (elapsed.TotalHours < 1)
        {
            return "just now";
        }

        if (elapsed.TotalHours < 24)
        {
            return $"{(int)elapsed.TotalHours} hour{((int)elapsed.TotalHours == 1 ? "" : "s")} ago";
        }

        if (elapsed.TotalDays < 2)
        {
            return "yesterday";
        }

        return Task.CompletedAt.Value.ToString("MMM dd");
    }

    private string GetCategoryLabel()
        => Task.Category switch
        {
            TaskCategory.Work => "Product Design",
            TaskCategory.Shopping => "Operations",
            TaskCategory.Health => "Marketing",
            TaskCategory.Personal => "Personal",
            _ => "General"
        };

    private string GetPriorityIcon()
        => Task.Priority switch
        {
            Priority.High => "keyboard_double_arrow_up",
            Priority.Medium => "remove",
            _ => "keyboard_double_arrow_down"
        };

    private string FormatDueDate(DateTime date)
    {
        var today = DateTime.UtcNow.Date;
        if (date.Date == today)
            return "Today";
        if (date.Date == today.AddDays(1))
            return "Tomorrow";
        if (date.Date == today.AddDays(-1))
            return "Due Yesterday";
        if (date.Date < today)
            return $"Due {date:MMM dd}";

        return date.ToString("MMM dd, yyyy");
    }
}
