@page "/tasks"
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using TodoApp.Models
@using TodoApp.Models.Enums
@using TodoApp.Services
@attribute [Authorize]
@inject ITaskService TaskService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject ILogger<Tasks> Logger

<PageTitle>Dashboard - Tasks</PageTitle>

<div class="dashboard-shell">
    <header class="dashboard-hero">
        <div class="dashboard-hero-copy">
            <h1 class="dashboard-greeting">@Greeting, @DisplayName.</h1>
            <p class="dashboard-subtitle">@HeroSubtitle</p>
        </div>
        <a href="/tasks/add" class="btn btn-primary btn-lg dashboard-cta">
            <span class="icon-text">
                <span class="ui-icon" aria-hidden="true">add_circle</span>
                <span>Create New Task</span>
            </span>
        </a>
    </header>

    <section class="metric-grid" aria-label="Task metrics">
        <div class="metric-card">
            <div class="metric-label icon-text"><span class="ui-icon" aria-hidden="true">checklist</span><span>Total Tasks</span></div>
            <div class="metric-value">@FormatCount(TasksList.Count)</div>
        </div>
        <div class="metric-card metric-primary">
            <div class="metric-label icon-text"><span class="ui-icon" aria-hidden="true">pending_actions</span><span>Pending</span></div>
            <div class="metric-value">@FormatCount(PendingTasks.Count)</div>
        </div>
        <div class="metric-card">
            <div class="metric-label icon-text"><span class="ui-icon" aria-hidden="true">task_alt</span><span>Completed</span></div>
            <div class="metric-value">@FormatCount(CompletedTasks.Count)</div>
        </div>
        <div class="metric-card metric-warning">
            <div class="metric-label icon-text"><span class="ui-icon" aria-hidden="true">warning</span><span>Overdue</span></div>
            <div class="metric-value">@FormatCount(OverdueCount)</div>
        </div>
    </section>

    <div class="dashboard-grid">
        <aside class="dashboard-rail dashboard-sidebar" aria-label="Task navigation sidebar">
            <div class="sidebar-brand-block">
                <div class="sidebar-brand-name">Taskflow</div>
                <div class="sidebar-brand-subtitle">Productivity Engine</div>
            </div>

            <a href="/tasks/add" class="btn btn-primary sidebar-create-btn">
                <span class="icon-text">
                    <span class="ui-icon" aria-hidden="true">add_circle</span>
                    <span>Create Task</span>
                </span>
            </a>

            <nav class="sidebar-nav-links" aria-label="Task sections">
                <a class="sidebar-link @(IsViewActive("inbox") ? "active" : "")" href="@BuildViewHref("inbox")">
                    <span class="sidebar-link-icon" aria-hidden="true"><span class="ui-icon">inbox</span></span>
                    <span>Inbox</span>
                </a>
                <a class="sidebar-link @(IsViewActive("today") ? "active" : "")" href="@BuildViewHref("today")">
                    <span class="sidebar-link-icon" aria-hidden="true"><span class="ui-icon">today</span></span>
                    <span>Today</span>
                </a>
                <a class="sidebar-link @(IsViewActive("upcoming") ? "active" : "")" href="@BuildViewHref("upcoming")">
                    <span class="sidebar-link-icon" aria-hidden="true"><span class="ui-icon">event_upcoming</span></span>
                    <span>Upcoming</span>
                </a>
                <a class="sidebar-link @(IsFiltersView ? "active" : "")" href="@BuildViewHref("filters")">
                    <span class="sidebar-link-icon" aria-hidden="true"><span class="ui-icon">filter_alt</span></span>
                    <span>Filters</span>
                </a>
                <a class="sidebar-link @(IsViewActive("archive") ? "active" : "")" href="@BuildViewHref("archive")">
                    <span class="sidebar-link-icon" aria-hidden="true"><span class="ui-icon">inventory_2</span></span>
                    <span>Archive</span>
                </a>
            </nav>

            <div class="sidebar-bottom-links">
                <a class="sidebar-link" href="/settings">
                    <span class="sidebar-link-icon" aria-hidden="true"><span class="ui-icon">settings</span></span>
                    <span>Settings</span>
                </a>
                <a class="sidebar-link" href="/tasks">
                    <span class="sidebar-link-icon" aria-hidden="true"><span class="ui-icon">help</span></span>
                    <span>Help</span>
                </a>
            </div>
        </aside>

        <div class="dashboard-main">
            <div class="dashboard-mobile-filter"></div>
            @if (IsFiltersView)
            {
                <section class="filters-panel" aria-label="Filters">
                    <div class="filters-panel-head">
                        <h2 class="filters-panel-title icon-text"><span class="ui-icon" aria-hidden="true">tune</span><span>Filters</span></h2>
                        <a href="/tasks?view=filters" class="filter-btn text-decoration-none icon-text"><span class="ui-icon" aria-hidden="true">clear_all</span><span>Clear</span></a>
                    </div>

                    <div class="filters-group">
                        <div class="filters-label icon-text"><span class="ui-icon" aria-hidden="true">playlist_add_check</span><span>Status</span></div>
                        <div class="filters-options">
                            <a class="filter-btn text-decoration-none icon-text @(SelectedStatusValue == "all" ? "active" : "")" href="@BuildFilterHref(status: "all")"><span class="ui-icon" aria-hidden="true">apps</span><span>All</span></a>
                            <a class="filter-btn text-decoration-none icon-text @(SelectedStatusValue == "pending" ? "active" : "")" href="@BuildFilterHref(status: "pending")"><span class="ui-icon" aria-hidden="true">schedule</span><span>Pending</span></a>
                            <a class="filter-btn text-decoration-none icon-text @(SelectedStatusValue == "completed" ? "active" : "")" href="@BuildFilterHref(status: "completed")"><span class="ui-icon" aria-hidden="true">task_alt</span><span>Completed</span></a>
                        </div>
                    </div>

                    <div class="filters-group">
                        <div class="filters-label icon-text"><span class="ui-icon" aria-hidden="true">flag</span><span>Priority</span></div>
                        <div class="filters-options">
                            <a class="filter-btn text-decoration-none icon-text @(SelectedPriority == null ? "active" : "")" href="@BuildFilterHref(priority: null)"><span class="ui-icon" aria-hidden="true">apps</span><span>All</span></a>
                            @foreach (var priority in Enum.GetValues<Priority>())
                            {
                                <a class="filter-btn text-decoration-none icon-text @(SelectedPriority == priority ? "active" : "")"
                                   href="@BuildFilterHref(priority: priority.ToString().ToLowerInvariant())">
                                    <span class="ui-icon" aria-hidden="true">@GetPriorityIcon(priority)</span>
                                    <span>@priority</span>
                                </a>
                            }
                        </div>
                    </div>

                    <div class="filters-group">
                        <div class="filters-label icon-text"><span class="ui-icon" aria-hidden="true">category</span><span>Category</span></div>
                        <div class="filters-options">
                            <a class="filter-btn text-decoration-none icon-text @(SelectedCategory == null ? "active" : "")" href="@BuildFilterHref(category: null)"><span class="ui-icon" aria-hidden="true">apps</span><span>All</span></a>
                            @foreach (var category in Enum.GetValues<TaskCategory>())
                            {
                                <a class="filter-btn text-decoration-none icon-text @(SelectedCategory == category ? "active" : "") category-@category.ToString().ToLowerInvariant()"
                                   href="@BuildFilterHref(category: category.ToString().ToLowerInvariant())">
                                    <span class="category-dot"></span><span>@category.GetDisplayLabel()</span>
                                </a>
                            }
                        </div>
                    </div>

                    <div class="filters-group">
                        <div class="filters-options">
                            <a class="filter-btn text-decoration-none icon-text @(OverdueOnly ? "active" : "")" href="@BuildFilterHref(overdue: !OverdueOnly)">
                                @if (OverdueOnly)
                                {
                                    <span class="ui-icon" aria-hidden="true">toggle_on</span>
                                    <span>Overdue Only On</span>
                                }
                                else
                                {
                                    <span class="ui-icon" aria-hidden="true">toggle_off</span>
                                    <span>Overdue Only Off</span>
                                }
                            </a>
                        </div>
                    </div>
                </section>
            }

            <div class="tasks-container">
                @if (IsLoading)
                {
                    <div class="skeleton-grid" aria-busy="true" aria-live="polite" aria-label="Loading tasks">
                        <div class="skeleton-card"></div>
                        <div class="skeleton-card"></div>
                        <div class="skeleton-card"></div>
                        <div class="skeleton-card"></div>
                        <div class="skeleton-card"></div>
                        <div class="skeleton-card"></div>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(LoadError))
                {
                    <div class="alert alert-danger d-flex flex-wrap align-items-center justify-content-between gap-2" role="alert" aria-live="polite">
                        <span>@LoadError</span>
                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="ReloadTasksAsync">Retry</button>
                    </div>
                }
                else if (!FilteredTasks.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon"><span class="ui-icon" aria-hidden="true">playlist_add_check_circle</span></div>
                        <h3>No tasks found</h3>
                        <p>You have no tasks matching the selected filter.</p>
                        <a href="/tasks/add" class="btn btn-primary mt-3 icon-text"><span class="ui-icon" aria-hidden="true">add_circle</span><span>Create your first task</span></a>
                    </div>
                }
                else
                {
                    @if (FilteredPendingTasks.Any())
                    {
                        <section class="task-group">
                            <div class="task-group-head">
                                <h2 class="task-group-title">@PrimaryTaskGroupTitle</h2>
                                <span class="task-count-pill">@FilteredPendingTasks.Count() Tasks</span>
                            </div>
                            <div class="task-list">
                                @foreach (var task in FilteredPendingTasks)
                                {
                                    <TaskCard Task="@task" />
                                }
                            </div>
                        </section>
                    }

                    @if (FilteredCompletedTasks.Any())
                    {
                        <section class="task-group mt-4">
                            <div class="task-group-head">
                                <h2 class="task-group-title text-muted">@(IsArchiveView ? "Archive" : "Recently Completed")</h2>
                            </div>
                            <div class="task-list task-list-compact">
                                @foreach (var task in IsArchiveView ? FilteredCompletedTasks : FilteredCompletedTasks.Take(4))
                                {
                                    <TaskCard Task="@task" Compact="true" />
                                }
                            </div>
                        </section>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "category")]
    public string? SelectedCategoryString { get; set; }

    [SupplyParameterFromQuery(Name = "view")]
    public string? SelectedView { get; set; }

    [SupplyParameterFromQuery(Name = "priority")]
    public string? SelectedPriorityString { get; set; }

    [SupplyParameterFromQuery(Name = "status")]
    public string? SelectedStatus { get; set; }

    [SupplyParameterFromQuery(Name = "overdue")]
    public bool OverdueOnly { get; set; }

    private TaskCategory? SelectedCategory => Enum.TryParse<TaskCategory>(SelectedCategoryString, true, out var parsedCategory)
        ? parsedCategory
        : null;
    private Priority? SelectedPriority => Enum.TryParse<Priority>(SelectedPriorityString, true, out var parsedPriority)
        ? parsedPriority
        : null;

    private List<TaskItem> TasksList { get; set; } = new();
    private bool IsLoading { get; set; } = true;
    private string? LoadError { get; set; }
    private string UserId { get; set; } = string.Empty;
    private string DisplayName { get; set; } = "there";

    private List<TaskItem> PendingTasks => TasksList.Where(t => !t.IsCompleted).ToList();
    private List<TaskItem> CompletedTasks => TasksList.Where(t => t.IsCompleted).ToList();

    private int OverdueCount => PendingTasks.Count(t => t.DueDate.HasValue && t.DueDate.Value.Date < DateTime.UtcNow.Date);
    private int DueTodayHighPriorityCount => PendingTasks.Count(t => t.Priority == Priority.High && t.DueDate.HasValue && t.DueDate.Value.Date == DateTime.UtcNow.Date);

    private int CompletionPercent => TasksList.Count == 0 ? 0 : (int)Math.Round((CompletedTasks.Count / (double)TasksList.Count) * 100.0);
    private int GoalTarget => Math.Max(40, TasksList.Count);
    private int GoalPercent => GoalTarget == 0 ? 0 : Math.Min(100, (int)Math.Round((CompletedTasks.Count / (double)GoalTarget) * 100.0));
    private int InboxCount => PendingTasks.Count;
    private int TodayCount => PendingTasks.Count(t => t.DueDate.HasValue && t.DueDate.Value.Date == TodayUtc);
    private int UpcomingCount => PendingTasks.Count(t => t.DueDate.HasValue && t.DueDate.Value.Date > TodayUtc);
    private int ArchiveCount => CompletedTasks.Count;
    private bool IsArchiveView => string.Equals(SelectedView, "archive", StringComparison.OrdinalIgnoreCase);
    private bool IsTodayView => string.Equals(SelectedView, "today", StringComparison.OrdinalIgnoreCase);
    private bool IsUpcomingView => string.Equals(SelectedView, "upcoming", StringComparison.OrdinalIgnoreCase);
    private bool IsFiltersView => string.Equals(SelectedView, "filters", StringComparison.OrdinalIgnoreCase);
    private string SelectedStatusValue => string.IsNullOrWhiteSpace(SelectedStatus) ? "all" : SelectedStatus.ToLowerInvariant();
    private bool IsInboxView => string.IsNullOrWhiteSpace(SelectedView) || string.Equals(SelectedView, "inbox", StringComparison.OrdinalIgnoreCase);
    private DateTime TodayUtc => DateTime.UtcNow.Date;
    private string PrimaryTaskGroupTitle
        => IsTodayView
            ? "Today"
            : IsUpcomingView
                ? "Upcoming"
                : IsArchiveView
                    ? "Completed"
                    : IsFiltersView
                        ? "Filtered Results"
                        : "Pending Focus";

    private string Greeting
    {
        get
        {
            var hour = DateTime.Now.Hour;
            if (hour < 12) return "Good morning";
            if (hour < 18) return "Good afternoon";
            return "Good evening";
        }
    }

    private string HeroSubtitle
        => DueTodayHighPriorityCount > 0
            ? $"You have {DueTodayHighPriorityCount} high-priority task{(DueTodayHighPriorityCount == 1 ? "" : "s")} requiring immediate attention today."
            : (OverdueCount > 0
                ? $"You have {OverdueCount} overdue task{(OverdueCount == 1 ? "" : "s")} that need attention."
                : "Your inbox is clear—add a task and keep moving.");

    private string FormatCount(int count) => count.ToString("00");
    private static string GetPriorityIcon(Priority priority)
        => priority switch
        {
            Priority.High => "keyboard_double_arrow_up",
            Priority.Medium => "remove",
            _ => "keyboard_double_arrow_down"
        };

    private bool IsViewActive(string view)
        => string.Equals(view, "inbox", StringComparison.OrdinalIgnoreCase)
            ? IsInboxView
            : string.Equals(SelectedView, view, StringComparison.OrdinalIgnoreCase);

    private string BuildViewHref(string view)
    {
        if (string.Equals(view, "inbox", StringComparison.OrdinalIgnoreCase))
        {
            return SelectedCategory.HasValue
                ? $"/tasks?category={SelectedCategory.Value.ToString().ToLowerInvariant()}"
                : "/tasks";
        }

        return SelectedCategory.HasValue
            ? $"/tasks?view={view}&category={SelectedCategory.Value.ToString().ToLowerInvariant()}"
            : $"/tasks?view={view}";
    }

    private string BuildFilterHref(string? status = null, string? priority = null, string? category = null, bool? overdue = null)
    {
        var parts = new List<string> { "view=filters" };

        var statusValue = status ?? SelectedStatusValue;
        if (!string.Equals(statusValue, "all", StringComparison.OrdinalIgnoreCase))
        {
            parts.Add($"status={statusValue.ToLowerInvariant()}");
        }

        var priorityValue = priority ?? SelectedPriority?.ToString().ToLowerInvariant();
        if (!string.IsNullOrWhiteSpace(priorityValue))
        {
            parts.Add($"priority={priorityValue.ToLowerInvariant()}");
        }

        var categoryValue = category ?? SelectedCategory?.ToString().ToLowerInvariant();
        if (!string.IsNullOrWhiteSpace(categoryValue))
        {
            parts.Add($"category={categoryValue.ToLowerInvariant()}");
        }

        var overdueValue = overdue ?? OverdueOnly;
        if (overdueValue)
        {
            parts.Add("overdue=true");
        }

        return $"/tasks?{string.Join("&", parts)}";
    }

    private IEnumerable<TaskItem> ViewFilteredTasks
        => IsArchiveView
            ? CompletedTasks
            : IsTodayView
                ? PendingTasks.Where(t => t.DueDate.HasValue && t.DueDate.Value.Date == TodayUtc)
                : IsUpcomingView
                    ? PendingTasks.Where(t => t.DueDate.HasValue && t.DueDate.Value.Date > TodayUtc)
                    : IsFiltersView
                        ? TasksList
                        : PendingTasks;
    private IEnumerable<TaskItem> FilteredTasks
    {
        get
        {
            var filtered = ViewFilteredTasks;

            if (SelectedCategory.HasValue)
            {
                filtered = filtered.Where(t => t.Category == SelectedCategory.Value);
            }

            if (SelectedPriority.HasValue)
            {
                filtered = filtered.Where(t => t.Priority == SelectedPriority.Value);
            }

            if (SelectedStatusValue == "pending")
            {
                filtered = filtered.Where(t => !t.IsCompleted);
            }
            else if (SelectedStatusValue == "completed")
            {
                filtered = filtered.Where(t => t.IsCompleted);
            }

            if (OverdueOnly)
            {
                filtered = filtered.Where(t => !t.IsCompleted && t.DueDate.HasValue && t.DueDate.Value.Date < TodayUtc);
            }

            return filtered;
        }
    }

    private IEnumerable<TaskItem> FilteredPendingTasks => FilteredTasks.Where(t => !t.IsCompleted)
        .OrderByDescending(t => t.DueDate.HasValue && t.DueDate.Value.Date < DateTime.UtcNow.Date) // Overdue first
        .ThenBy(t => t.DueDate ?? DateTime.MaxValue) // Then by due date
        .ThenByDescending(t => t.Priority);

    private IEnumerable<TaskItem> FilteredCompletedTasks => FilteredTasks.Where(t => t.IsCompleted)
        .OrderByDescending(t => t.CompletedAt ?? DateTime.MinValue);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        UserId = authState.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? string.Empty;
        DisplayName = authState.User.Identity?.Name ?? "there";

        await ReloadTasksAsync();
    }

    private async Task ReloadTasksAsync()
    {
        IsLoading = true;
        LoadError = null;
        try
        {
            if (!string.IsNullOrEmpty(UserId))
            {
                TasksList = await TaskService.GetTasksAsync(UserId);
            }
            else
            {
                TasksList = new();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load tasks for user {UserId}", UserId);
            LoadError = "We couldn't load your tasks. Check your connection and try again.";
            TasksList = new();
        }
        finally
        {
            IsLoading = false;
        }
    }
}
