@page "/login"
@inject NavigationManager NavigationManager

<PageTitle>Login</PageTitle>

<div class="auth-container">
    <div class="auth-card shadow-sm">
        <h2 class="text-center mb-4">Login</h2>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger" role="alert">
                @ErrorMessage
            </div>
        }

        <form action="Account/Login" method="post" @formname="LoginForm">
            <AntiforgeryToken />

            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />

            <div class="form-group mb-3">
                <label for="login-identifier" class="form-label icon-text">
                    <span class="ui-icon" aria-hidden="true">person</span>
                    <span>Email or Username</span>
                </label>
                <input
                    type="text"
                    name="LoginIdentifier"
                    id="login-identifier"
                    class="form-control"
                    placeholder="name@example.com or username"
                    required
                    @bind="LoginIdentifier" />
            </div>

            <div class="form-group mb-4">
                <label for="password" class="form-label icon-text">
                    <span class="ui-icon" aria-hidden="true">lock</span>
                    <span>Password</span>
                </label>
                <input
                    type="@LoginPasswordInputType"
                    name="Password"
                    id="password"
                    class="form-control"
                    placeholder="Password"
                    required
                    @bind="LoginPassword" />
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="show-login-password" @bind="ShowLoginPassword" />
                    <label class="form-check-label icon-text" for="show-login-password">
                        <span class="ui-icon" aria-hidden="true">visibility</span>
                        <span>Show password</span>
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary w-100 icon-text">
                <span class="ui-icon" aria-hidden="true">login</span>
                <span>Log in</span>
            </button>

            <div class="text-center mt-3">
                <p>Don't have an account? <a href="/register">Register here</a>.</p>
            </div>
        </form>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorMessage { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    private string LoginIdentifier { get; set; } = string.Empty;
    private string LoginPassword { get; set; } = string.Empty;
    private bool ShowLoginPassword { get; set; }
    private string LoginPasswordInputType => ShowLoginPassword ? "text" : "password";
}
